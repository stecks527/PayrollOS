/*************************************************
 * 36 PAYROLL - WEEKLY GENERATE
 * Version: 2.1.0
 * Status: ACTIVE / CANONICAL
 *
 * Single public Payroll generation pipeline.
 *
 * PayrollScheduleOS owns every scheduling decision.
 * PayrollWriterOS writes the call grid.
 * PayrollNotesOS builds notes from the same model.
 * PayrollNotesWriterOS writes editable notes.
 *
 * No direct IN/OUT-to-Payroll cell patching.
 * No PAYROLLNOTES formula refresh.
 *************************************************/


/* =========================================================
 * PUBLIC PAYROLLOS API
 * ========================================================= */

function PayrollOS() {
  return {
    refresh:
      payrollOSRefresh_,

    current:
      payrollOSCurrent_,

    notes:
      payrollOSRefreshNotesOnly_,

    clearCache:
      payrollOSClearCache_,

    status:
      payrollOSStatus_
  };
}


/* =========================================================
 * PUBLIC MENU / LEGACY ENTRY POINT
 * ========================================================= */

function fillPayrollFromCurrentWeekly() {
  return openPayrollOSPreview();
}


/* =========================================================
 * CANONICAL REFRESH
 * ========================================================= */

function payrollOSRefresh_(
  options
) {
  options =
    Object.assign(
      {
        forceBuild:
          true,

        writeGrid:
          true,

        writeNotes:
          true,

        showAlert:
          false
      },
      options || {}
    );

  const startedAt =
    Date.now();

  const ss =
    SpreadsheetApp
      .getActiveSpreadsheet();

  const payroll =
    ss.getSheetByName(
      "Payroll"
    );

  const weekly =
    getCurrentPayrollWeeklyScheduleSheet_();

  if (!payroll) {
    throw new Error(
      'Could not find the "Payroll" tab.'
    );
  }

  if (!weekly) {
    throw new Error(
      "Current Weekly Schedule tab not found."
    );
  }

  payrollOSRequireCanonicalModules_();

  /*
   * Build the structured weekly model exactly once.
   *
   * forceBuild=true is the safe path after Prep, Weekly,
   * PD/Vacation, or company-state changes.
   */
  const schedule =
    options.forceBuild
      ? PayrollScheduleOS()
          .build()
      : PayrollScheduleOS()
          .current();

  const notes =
    PayrollNotesOS()
      .build(
        schedule
      );

  /*
   * Keep the displayed week-start date synchronized with
   * the Weekly sheet selected by PayrollScheduleOS.
   */
  payroll
  .getRange("D2")
  .setValue(
    getMondayDateFromWeekly_(
      weekly
    )
  );

  const payrollResult =
    options.writeGrid
      ? PayrollWriterOS()
          .write(
            schedule
          )
      : {
          success:
            true,

          writes:
            0,

          notes: []
        };

  const notesResult =
    options.writeNotes
      ? PayrollNotesWriterOS()
          .write(
            notes
          )
      : {
          success:
            true,

          writtenCells:
            [],

          missingCoveragePerformances:
            notes.counts
              .missingCoveragePerformances
        };

  const result = {
    success:
      Boolean(
        payrollResult.success &&
        notesResult.success
      ),

    source:
      "PayrollScheduleOS",

    weeklySheet:
      schedule.weeklySheet,

    weekStart:
      schedule.weekStart,

    weekEnd:
      schedule.weekEnd,

    people:
      schedule.counts.people,

    outPerformances:
      schedule.counts.outs,

    coveragePerformances:
      schedule.counts.coverage,

    payrollCellsWritten:
      payrollResult.writes || 0,

    payrollNotesWritten:
      Boolean(
        options.writeNotes &&
        notesResult.success
      ),

    notesCells:
      notesResult.writtenCells || [],

    missingCoverage:
      notesResult
        .missingCoveragePerformances || 0,

    writerNotes:
      payrollResult.notes || [],

    durationMs:
      Date.now() -
      startedAt
  };

  Logger.log(
    "PAYROLLOS CANONICAL REFRESH"
  );

  Logger.log(
    JSON.stringify(
      result,
      null,
      2
    )
  );

  if (
    options.showAlert
  ) {
    SpreadsheetApp
      .getUi()
      .alert(
        [
          "Payroll generated successfully.",
          "",
          "Week: " +
            result.weekStart +
            " through " +
            result.weekEnd,
          "People: " +
            result.people,
          "OUT performances: " +
            result.outPerformances,
          "Coverage performances: " +
            result.coveragePerformances,
          "Missing coverage: " +
            result.missingCoverage,
          "Payroll cells written: " +
            result.payrollCellsWritten,
          "Notes written to: " +
            (
              result.notesCells.length
                ? result.notesCells.join(", ")
                : "Not requested"
            ),
          "Duration: " +
            result.durationMs +
            " ms"
        ].join("\n")
      );
  }

  return result;
}


/* =========================================================
 * NORMAL READ
 * ========================================================= */

function payrollOSCurrent_() {
  payrollOSRequireCanonicalModules_();

  const schedule =
    PayrollScheduleOS()
      .current();

  const notes =
    PayrollNotesOS()
      .build(
        schedule
      );

  return {
    schedule:
      schedule,

    notes:
      notes
  };
}


