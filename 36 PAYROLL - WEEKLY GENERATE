    system:
      "PayrollOS",

    version:
      "2.1.0",

    scheduleOSAvailable:
      typeof PayrollScheduleOS ===
      "function",

    writerOSAvailable:
      typeof PayrollWriterOS ===
      "function",

    notesOSAvailable:
      typeof PayrollNotesOS ===
      "function",

    notesWriterOSAvailable:
      typeof PayrollNotesWriterOS ===
