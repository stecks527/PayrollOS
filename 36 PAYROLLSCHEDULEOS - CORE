/*************************************************
 * PAYROLL SCHEDULE OS
 * Version: 1.2.0
 *
 * current()
 * - Returns the cached weekly model when available.
 * - Rebuilds and caches it when necessary.
 *
 * build()
 * - Forces a fresh rebuild of the current week.
 *************************************************/

function PayrollScheduleOS() {
  return {
    /*
     * Upcoming/current generator week.
     * This intentionally continues to use the Weekly tab
     * selected by getCurrentPayrollWeeklyScheduleSheet_().
     */
    current:
      payrollScheduleOSCurrent_,

    build:
      payrollScheduleOSForceBuild_,

    /*
     * Explicit-week path.
     * Used when Payroll Notes must rebuild the week already
     * displayed on the Payroll sheet instead of the upcoming
     * Weekly tab.
     */
    currentForSheet:
      payrollScheduleOSCurrentForSheet_,

    buildForSheet:
      payrollScheduleOSForceBuildForSheet_,

    clearCache:
      payrollScheduleOSClearCache_,

    status:
      payrollScheduleOSStatus_,

    test:
      testPayrollScheduleOS
  };
}


/* =========================================================
 * CURRENT WEEK
 *
 * Normal read path. Prefer the cached weekly model.
 * ========================================================= */

function payrollScheduleOSCurrent_() {
  const weekly =
    getCurrentPayrollWeeklyScheduleSheet_();

  if (!weekly) {
    throw new Error(
      "Current Weekly Schedule tab not found."
    );
  }

  const cacheKey =
    payrollScheduleOSCacheKey_(
      weekly
    );

  const cached =
    payrollScheduleOSGetCached_(
      cacheKey
    );

  if (cached) {
    Logger.log(
      "PayrollScheduleOS source: cache"
    );

    return cached;
  }

  Logger.log(
    "PayrollScheduleOS source: rebuilt"
  );

  const schedule =
    payrollScheduleOSBuild_(
      weekly
    );

  payrollScheduleOSSetCached_(
    cacheKey,
    schedule
  );

  return schedule;
}


/* =========================================================
 * EXPLICIT WEEKLY SHEET
 *
 * These paths never choose a Weekly tab on their own.
 * The caller supplies the exact Weekly Schedule sheet.
 * ========================================================= */

function payrollScheduleOSCurrentForSheet_(
  weekly
) {
  payrollScheduleOSRequireWeeklySheet_(
    weekly
  );

  const cacheKey =
    payrollScheduleOSCacheKey_(
      weekly
    );

  const cached =
    payrollScheduleOSGetCached_(
      cacheKey
    );

  if (cached) {
    Logger.log(
      "PayrollScheduleOS explicit source: cache"
    );

    return cached;
  }

  const schedule =
    payrollScheduleOSBuild_(
      weekly
    );

  payrollScheduleOSSetCached_(
    cacheKey,
    schedule
  );

  Logger.log(
    "PayrollScheduleOS explicit source: rebuilt"
  );

  return schedule;
}


function payrollScheduleOSForceBuildForSheet_(
  weekly
) {
  payrollScheduleOSRequireWeeklySheet_(
    weekly
  );

  const cacheKey =
    payrollScheduleOSCacheKey_(
      weekly
    );

  const schedule =
    payrollScheduleOSBuild_(
      weekly
    );

  payrollScheduleOSSetCached_(
    cacheKey,
    schedule
  );

  Logger.log(
    "PayrollScheduleOS explicit forced rebuild complete: " +
    weekly.getName()
  );

  return schedule;
}


function payrollScheduleOSRequireWeeklySheet_(
  weekly
) {
  if (
    !weekly ||
    typeof weekly.getName !==
      "function"
  ) {
    throw new Error(
      "A valid Weekly Schedule sheet is required."
    );
  }

  if (
    !/^Weekly Schedule Mon/i.test(
      weekly.getName()
    )
  ) {
    throw new Error(
      'Expected a "Weekly Schedule Mon..." sheet, received "' +
      weekly.getName() +
      '".'
    );
  }
}


/* =========================================================
 * FORCED BUILD
 *
 * Developer/manual refresh path.
 * Always rebuilds and replaces the cache.
 * ========================================================= */

function payrollScheduleOSForceBuild_() {
  const weekly =
    getCurrentPayrollWeeklyScheduleSheet_();

  if (!weekly) {
    throw new Error(
      "Current Weekly Schedule tab not found."
    );
  }

  const cacheKey =
    payrollScheduleOSCacheKey_(
      weekly
    );

  const schedule =
    payrollScheduleOSBuild_(
      weekly
    );

  payrollScheduleOSSetCached_(
    cacheKey,
    schedule
  );

  Logger.log(
    "PayrollScheduleOS forced rebuild complete."
  );

  return schedule;
}


/* =========================================================
 * CACHE
 *
 * CacheService avoids Document Properties quota problems.
 * The cache survives separate Apps Script executions.
 * ========================================================= */

function payrollScheduleOSCacheKey_(
  weekly
) {
  const weeklyName =
    weekly
      ? weekly.getName()
      : "NO_WEEKLY";

  return (
    "PAYROLL_SCHEDULE_OS_V1|" +
    weeklyName
  );
}


function payrollScheduleOSGetCached_(
  cacheKey
) {
  try {
    const cache =
      CacheService
        .getDocumentCache();

    const raw =
      cache.get(
        cacheKey
      );

    if (!raw) {
      return null;
    }

    const parsed =
      JSON.parse(
        raw
      );

    if (
      !parsed ||
      !parsed.schedule
    ) {
      return null;
    }

    return parsed.schedule;

  } catch (err) {
    Logger.log(
      "PayrollScheduleOS cache read skipped: " +
      String(err)
    );

    return null;
  }
}


function payrollScheduleOSSetCached_(
  cacheKey,
  schedule
) {
  if (!schedule) {
    return false;
  }

  try {
    const payload =
      JSON.stringify({
        cachedAt:
          new Date()
            .toISOString(),

        schedule:
          schedule
      });

    /*
     * CacheService allows a maximum of roughly
     * 100 KB per key. Log and skip caching if this
     * model ever grows beyond a safe threshold.
     */
    if (
      payload.length >
      95000
    ) {
      Logger.log(
        "PayrollScheduleOS cache skipped because " +
        "the serialized model is too large: " +
        payload.length +
        " characters."
      );

      return false;
    }

    CacheService
      .getDocumentCache()
      .put(
        cacheKey,
        payload,
        21600
      );

    Logger.log(
      "PayrollScheduleOS cache written: " +
      payload.length +
      " characters."
    );

    return true;

  } catch (err) {
    Logger.log(
      "PayrollScheduleOS cache write skipped: " +
      String(err)
    );

    return false;
  }
}


function payrollScheduleOSClearCache_() {
  const weekly =
    getCurrentPayrollWeeklyScheduleSheet_();

  if (!weekly) {
    return false;
  }

  const cacheKey =
    payrollScheduleOSCacheKey_(
      weekly
    );

  CacheService
    .getDocumentCache()
    .remove(
      cacheKey
    );

  Logger.log(
    "PayrollScheduleOS cache cleared."
  );

  return true;
}


