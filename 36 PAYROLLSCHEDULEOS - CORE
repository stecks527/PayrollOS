function debugPayrollLeanaEmilyCorrectWeek() {
  const WEEKLY_SHEET_NAME =
    "Weekly Schedule Mon 7.13.26 - Sun 7.19.26";

  const TARGET_DATE =
    "2026-07-18";

  const ss =
    SpreadsheetApp.getActiveSpreadsheet();

  const weekly =
    ss.getSheetByName(
      WEEKLY_SHEET_NAME
    );

  if (!weekly) {
    throw new Error(
      'Could not find "' +
      WEEKLY_SHEET_NAME +
      '".'
    );
  }

  /*
   * Build directly from the requested Weekly tab.
   * This intentionally bypasses current() and its cache.
   */
  const schedule =
    payrollScheduleOSBuild_(
      weekly
    );

  function findPersonDay(
    personName
  ) {
    const wantedKey =
      payrollScheduleOSNameKey_(
        personName
      );

    const person =
      (schedule.people || [])
        .find(function (item) {
          return (
            payrollScheduleOSNameKey_(
              item.name
            ) === wantedKey
          );
        });

    if (!person) {
      return {
        personFound:
          false,

        day:
          null
      };
    }

    const day =
      (person.days || [])
        .find(function (item) {
          return (
            item.date ===
            TARGET_DATE
          );
        }) || null;

    return {
      personFound:
        true,

      person:
        person.name,

      day:
        day
    };
  }

  const result = {
    weeklySheet:
      schedule.weeklySheet,

    weekStart:
      schedule.weekStart,

    weekEnd:
      schedule.weekEnd,

    targetDate:
      TARGET_DATE,

    leana:
      findPersonDay(
        "Leana Rae Concepcion"
      ),

    emily:
      findPersonDay(
        "Emily N. Rudolph"
      ),

    counts:
      schedule.counts
  };

  Logger.log(
    "PAYROLL LEANA / EMILY CORRECT WEEK DEBUG"
  );

  Logger.log(
    JSON.stringify(
      result,
      null,
      2
    )
  );

  return result;
}
