function payrollScheduleOSBuild_(weekly) {
  const startedAt = Date.now();
  const ss = SpreadsheetApp.getActiveSpreadsheet();
  const payroll = ss.getSheetByName("Payroll");
  const castList = ss.getSheetByName("Cast List");

  if (!payroll) throw new Error('Could not find "Payroll".');
  if (!castList) throw new Error('Could not find "Cast List".');

  const monday = getMondayDateFromWeekly_(weekly);

const nameMap =
  buildPayrollNameMap_(castList);

const weeklyInfo =
  readWeeklyForPayroll_(
    weekly,
    nameMap
  );

/*
 * NEW
 */
const weeklyCoverageMap =
  payrollScheduleOSBuildWeeklyCoverageMap_(
    weekly,
    monday
  );

const personBlocks =
  getPayrollPersonBlocks_(payroll);

const outDraft =
  payrollBuildWeeklyOutDraft_(
    monday
  );

const coverageLedger =
  typeof prepGetCoverageLedger_ === "function"
    ? prepGetCoverageLedger_()
    : {};

  const people = personBlocks.map(function(person) {
    return {
      name: person.fullName,
      isStageManager: person.topRow < 19,
      topRow: person.topRow,
      bottomRow: person.bottomRow,
      hoursRow: person.hoursRow,
      days: []
    };
  });

  const peopleByName = {};
  people.forEach(function(person) {
    peopleByName[payrollScheduleOSNameKey_(person.name)] = person;
  });

  weeklyInfo.forEach(function(day, dayIndex) {
    people.forEach(function(person) {
      person.days.push(
        payrollScheduleOSBuildBaselineDay_(
          person,
          day,
          dayIndex,
          monday
        )
      );
    });
  });

  (outDraft.days || []).forEach(function(draftDay, dayIndex) {
    const weeklyDay = weeklyInfo[dayIndex];
    if (!weeklyDay) return;

    (draftDay.castOuts || []).forEach(function(out) {
      const person =
        peopleByName[payrollScheduleOSNameKey_(out.person)];

      if (!person) return;

      payrollScheduleOSApplyOut_(
        person.days[dayIndex],
        weeklyDay,
        out
      );
    });
  });

  payrollScheduleOSApplyCoverageLedger_(
    peopleByName,
    weeklyInfo,
    monday,
    coverageLedger
  );

  payrollScheduleOSApplyWeeklyResolvedCoverage_(
    peopleByName,
    weeklyInfo,
    monday,
    weeklyCoverageMap
  );

  return {
    system: "PayrollScheduleOS",
    version: "1.2.0",
    weeklySheet: weekly.getName(),
    weekStart: payrollScheduleOSDateKey_(monday),
    weekEnd: payrollScheduleOSDateKey_(
      payrollScheduleOSAddDays_(monday, 6)
    ),
    people: people,
    counts: {
      people: people.length,
      stageManagers: people.filter(p => p.isStageManager).length,
      actors: people.filter(p => !p.isStageManager).length,
      outs: payrollScheduleOSCountOuts_(people),
      coverage: payrollScheduleOSCountCoverage_(people),
      ledgerPerformances: Object.keys(coverageLedger || {}).length
    },
    durationMs: Date.now() - startedAt
  };
}

/*************************************************
 * APPLY WEEKLY RESOLVED COVERAGE
 *
 * Prep ledger coverage takes priority.
 * This fills only performances that still have
 * an OUT record with no covering actor.
 *************************************************/

function payrollScheduleOSApplyWeeklyResolvedCoverage_(
  peopleByName,
  weeklyInfo,
  monday,
  weeklyCoverageMap
) {
  let applied = 0;
  const unresolved = [];

  Object.keys(
    peopleByName
  ).forEach(
    function (personKey) {
      const outPerson =
        peopleByName[personKey];

      outPerson.days.forEach(
        function (dayModel, dayIndex) {
          const weeklyDay =
            weeklyInfo[dayIndex];

          if (!weeklyDay) {
            return;
          }

          const targetDate =
            payrollScheduleOSAddDays_(
              monday,
              dayIndex
            );

          const dateKey =
            payrollScheduleOSDateKey_(
              targetDate
            );

          (dayModel.outs || [])
            .forEach(
              function (out) {
                /*
                 * Swing outs may legitimately need
                 * no replacement.
                 */
                if (
                  !out.role ||
                  /^swing$/i.test(
                    String(
                      out.role
                    )
                  ) ||
                  out.noCoverNeeded ===
                    true
                ) {
                  return;
                }

                /*
                 * Do not replace exact coverage already
                 * confirmed through the Prep ledger.
                 */
                if (
                  payrollScheduleOSOutAlreadyCovered_(
                    peopleByName,
                    dayIndex,
                    out
                  )
                ) {
                  return;
                }

                let temporaryReplacement =
                  null;

                let coverName =
                  "";

                /*
                 * Priority 1:
                 * Temporary company replacement.
                 */
                if (
                  typeof CompanyTemporaryReplacementOS ===
                    "function"
                ) {
                  temporaryReplacement =
                    CompanyTemporaryReplacementOS()
                      .findForOut(
                        out.person ||
                          outPerson.name,
                        out.role,
                        targetDate
                      );

                  if (
                    temporaryReplacement &&
                    temporaryReplacement.replacement
                  ) {
                    coverName =
                      String(
                        temporaryReplacement.replacement
                      ).trim();
                  }
                }

                /*
                 * Priority 2:
                 * Prebuilt Weekly coverage map.
                 */
                if (!coverName) {
                  coverName =
                    payrollScheduleOSFindWeeklyCoverInMap_(
                      weeklyCoverageMap,
                      dateKey,
                      out.role
                    );
                }

                if (!coverName) {
                  unresolved.push({
                    out:
                      out.person ||
                      outPerson.name,

                    role:
                      out.role || "",

                    date:
                      dayModel.date,

                    part:
                      out.part ||
                      "Unknown"
                  });

                  return;
                }

                const coverPerson =
                  peopleByName[
                    payrollScheduleOSNameKey_(
                      coverName
                    )
                  ];

                if (!coverPerson) {
                  unresolved.push({
                    out:
                      out.person ||
                      outPerson.name,

                    role:
                      out.role || "",

                    date:
                      dayModel.date,

                    part:
                      out.part ||
                      "Unknown",

                    issue:
                      "Cover not found in Payroll roster: " +
                      coverName
                  });

                  return;
                }

                const coverDay =
                  coverPerson.days[
                    dayIndex
                  ];

                if (!coverDay) {
                  return;
                }

                payrollScheduleOSApplyWeeklyCoverage_(
                  coverDay,
                  out,
                  coverName,
                  dayModel.date,
                  temporaryReplacement
                    ? "Temporary Replacement Registry"
                    : "Weekly Schedule"
                );

                applied++;
              }
            );
        }
      );
    }
  );

  Logger.log(
    "PAYROLLSCHEDULEOS WEEKLY COVERAGE"
  );

  Logger.log(
    JSON.stringify(
      {
        applied:
          applied,

        unresolved:
          unresolved
      },
      null,
      2
    )
  );

  return {
    applied:
      applied,

    unresolved:
      unresolved
  };
}

/*************************************************
 * WEEKLY COVERAGE LOOKUP MAP
 *
 * Reads the current Weekly sheet once.
 *
 * Output:
 * {
 *   "2026-07-15": {
 *     "barfee": "Brandon L. Armstrong"
 *   }
 * }
 *************************************************/

function payrollScheduleOSBuildWeeklyCoverageMap_(
  weekly,
  monday
) {
  const values =
    weekly
      .getDataRange()
      .getDisplayValues();

  const map = {};

  let currentDateKey =
    "";

  for (
    let rowIndex = 0;
    rowIndex < values.length;
    rowIndex++
  ) {
    const row =
      values[rowIndex];

    const rowText =
      row
        .join(" ")
        .replace(/\s+/g, " ")
        .trim();

    const headerDate =
      payrollScheduleOSParseWeeklyHeaderDate_(
        rowText,
        monday
      );

    if (headerDate) {
      currentDateKey =
        payrollScheduleOSDateKey_(
          headerDate
        );

      if (!map[currentDateKey]) {
        map[currentDateKey] =
          {};
      }

      continue;
    }

    if (!currentDateKey) {
      continue;
    }

    const assignment =
      payrollScheduleOSParseWeeklyCoverageLine_(
        rowText
      );

    if (!assignment) {
      continue;
    }

    const fullCoverName =
      typeof expandActorNameFromCastList_ ===
        "function"
        ? expandActorNameFromCastList_(
            assignment.cover
          )
        : assignment.cover;

    const roleKeys =
      payrollScheduleOSWeeklyRoleKeys_(
        assignment.role
      );

    roleKeys.forEach(
      function (roleKey) {
        map[currentDateKey][roleKey] =
          fullCoverName;
      }
    );
  }

  Logger.log(
    "PAYROLLSCHEDULEOS WEEKLY COVERAGE MAP"
  );

  Logger.log(
    JSON.stringify(
      map,
      null,
      2
    )
  );

  return map;
}

function payrollScheduleOSParseWeeklyHeaderDate_(
  rowText,
  monday
) {
  const match =
    String(
      rowText || ""
    ).match(
      /\b(Monday|Tuesday|Wednesday|Thursday|Friday|Saturday|Sunday),\s+([A-Za-z]+)\s+(\d{1,2})\b/i
    );

  if (!match) {
    return null;
  }

  const year =
    monday.getFullYear();

  const parsed =
    new Date(
      match[2] +
      " " +
      match[3] +
      ", " +
      year +
      " 12:00:00"
    );

  if (
    isNaN(
      parsed.getTime()
    )
  ) {
    return null;
  }

  return parsed;
}

function payrollScheduleOSParseWeeklyCoverageLine_(
  rowText
) {
  const cleanText =
    String(
      rowText || ""
    )
      .replace(/\s+/g, " ")
      .trim();

  if (!cleanText) {
    return null;
  }

  /*
   * Example:
   * Kevin M. OUT, Barfée = Brandon A.
   */
  const match =
    cleanText.match(
      /\bOUT[, ]+\s*(.*?)\s*=\s*(.*?)$/i
    );

  if (!match) {
    return null;
  }

  const role =
    String(
      match[1] || ""
    ).trim();

  const cover =
    String(
      match[2] || ""
    ).trim();

  if (
    !role ||
    !cover
  ) {
    return null;
  }

  return {
    role:
      role,

    cover:
      cover
  };
}

function payrollScheduleOSFindWeeklyCoverInMap_(
  weeklyCoverageMap,
  dateKey,
  roleName
) {
  const dateMap =
    weeklyCoverageMap &&
    weeklyCoverageMap[
      dateKey
    ]
      ? weeklyCoverageMap[
          dateKey
        ]
      : null;

  if (!dateMap) {
    return "";
  }

  const roleKeys =
    payrollScheduleOSWeeklyRoleKeys_(
      roleName
    );

  for (
    let index = 0;
    index < roleKeys.length;
    index++
  ) {
    const cover =
      dateMap[
        roleKeys[index]
      ];

    if (cover) {
      return cover;
    }
  }

  return "";
}

function payrollScheduleOSWeeklyRoleKeys_(
  roleName
) {
  const keys = [];

  const normalized =
    typeof normalizeCoverRole_ ===
      "function"
      ? normalizeCoverRole_(
          roleName
        )
      : payrollScheduleOSNameKey_(
          roleName
        );

  if (normalized) {
    keys.push(
      normalized
    );
  }

  if (
    typeof shortRoleNameForWeekly_ ===
      "function"
  ) {
    const shortRole =
      shortRoleNameForWeekly_(
        roleName
      );

    const shortNormalized =
      typeof normalizeCoverRole_ ===
        "function"
        ? normalizeCoverRole_(
            shortRole
          )
        : payrollScheduleOSNameKey_(
            shortRole
          );

    if (
      shortNormalized &&
      keys.indexOf(
        shortNormalized
      ) === -1
    ) {
      keys.push(
        shortNormalized
      );
    }
  }

  return keys;
}

/*************************************************
 * CHECK WHETHER AN OUT ALREADY HAS COVERAGE
 *************************************************/

function payrollScheduleOSOutAlreadyCovered_(
  peopleByName,
  dayIndex,
  out
) {
  const outNameKey =
    payrollScheduleOSNameKey_(
      out.person
    );

  const roleKey =
    payrollScheduleOSNameKey_(
      out.role
    );

  const part =
    String(
      out.part || "Unknown"
    );

  return Object.keys(
    peopleByName
  ).some(
    function (personKey) {
      const person =
        peopleByName[personKey];

      const day =
        person.days[
          dayIndex
        ];

      if (!day) {
        return false;
      }

      return (day.coverage || [])
        .some(
          function (coverage) {
            return (
              payrollScheduleOSNameKey_(
                coverage.out
              ) === outNameKey &&
              payrollScheduleOSNameKey_(
                coverage.role
              ) === roleKey &&
              String(
                coverage.part || "Unknown"
              ) === part
            );
          }
        );
    }
  );
}


/*************************************************
 * APPLY ONE WEEKLY COVERAGE RECORD
 *************************************************/

function payrollScheduleOSApplyWeeklyCoverage_(
  coverDay,
  out,
  coverName,
  dateKey,
  source
) {
  const part =
    out.part || "Unknown";

  /*
   * Remove the cover actor's normal SHOW call for
   * this performance, but preserve rehearsal calls.
   */
  coverDay.calls =
    coverDay.calls.filter(
      function (call) {
        return !(
          call.type ===
            "SHOW" &&
          (
            call.part === part ||
            part === "Unknown"
          )
        );
      }
    );

  const coverage = {
    out:
      out.person || "",

    in:
      coverName,

    role:
      out.role || "",

    reason:
      out.reason || "",

    source:
      source ||
      "Weekly Schedule",

    part:
      part,

    date:
      dateKey,

    performance:
      "",

    text:
      "1 Show Call - IN as " +
      (
        out.role ||
        "Cover"
      )
  };

  const duplicate =
    (coverDay.coverage || [])
      .some(
        function (existing) {
          return (
            payrollScheduleOSNameKey_(
              existing.out
            ) ===
              payrollScheduleOSNameKey_(
                coverage.out
              ) &&
            payrollScheduleOSNameKey_(
              existing.in
            ) ===
              payrollScheduleOSNameKey_(
                coverage.in
              ) &&
            payrollScheduleOSNameKey_(
              existing.role
            ) ===
              payrollScheduleOSNameKey_(
                coverage.role
              ) &&
            String(
              existing.part || ""
            ) ===
              String(
                coverage.part || ""
              )
          );
        }
      );

  if (duplicate) {
    return;
  }

  coverDay.coverage.push(
    coverage
  );

  coverDay.calls.push({
    type:
      "COVERAGE",

    part:
      part,

    role:
      coverage.role,

    out:
      coverage.out,

    source:
      source ||
      "Weekly Schedule",

    text:
      coverage.text
  });
}

function payrollScheduleOSBuildBaselineDay_(
  person,
  day,
  dayIndex,
  monday
) {
  const date =
    payrollScheduleOSAddDays_(
      monday,
      dayIndex
    );

  const hasRehearsal =
    Boolean(
      day.rehearsalText
    );

  const isCalledForRehearsal =
    person.isStageManager ||
    day.calledFullNames.has(
      person.name
    );

  const showParts =
    (day.showParts || [])
      .slice();

  const multipleShows =
    showParts.length > 1;

  const calls = [];

  if (day.isOff) {
    calls.push({
      type:
        "AEA_DAY_OFF",

      part:
        "",

      text:
        "AEA DAY OFF"
    });

  } else {
    if (hasRehearsal) {
      calls.push({
        type:
          isCalledForRehearsal
            ? "REHEARSAL"
            : "REHEARSAL_NOT_CALLED",

        part:
          "",

        text:
          isCalledForRehearsal
            ? day.rehearsalText
            : "Rehearsal\n(Not Called)",

        hours:
          Number(
            day.rehearsalHours || 0
          )
      });
    }

    showParts.forEach(
      function (part) {
        calls.push({
          type:
            "SHOW",

          part:
            part,

          text:
            multipleShows
              ? (
                  part === "Mat"
                    ? "1 Show Call - Mat"
                    : part === "Eve"
                      ? "1 Show Call - Eve"
                      : "1 Show Call"
                )
              : "1 Show Call"
        });
      }
    );
  }

  return {
    date:
      payrollScheduleOSDateKey_(
        date
      ),

    isOff:
      Boolean(
        day.isOff
      ),

    rehearsalText:
      day.rehearsalText || "",

    rehearsalHours:
      Number(
        day.rehearsalHours || 0
      ),

    showParts:
      showParts,

    calls:
      calls,

    outs:
      [],

    coverage:
      []
  };
}

function payrollScheduleOSApplyOut_(dayModel, weeklyDay, out) {
  const parts = payrollGetOutPartsForDay_(weeklyDay, out);
  const reason = payrollGetOutReasonLabel_(out);

  parts.forEach(function(part) {
    dayModel.calls = dayModel.calls.filter(function(call) {
      return !(
        call.type === "SHOW" &&
        (call.part === part || part === "Unknown")
      );
    });

    dayModel.outs.push({
      person: out.person || "",
      role: out.role || "",
      reason: reason,
      part: part,
      approvalStatus: out.approvalStatus || "",
      appliesTo: out.appliesTo || "ALL",
      text: "OUT (" + reason + ")"
    });
  });
}

function payrollScheduleOSApplyCoverageLedger_(
  peopleByName,
  weeklyInfo,
  monday,
  ledger
) {
  Object.keys(
    ledger || {}
  ).forEach(
    function (key) {
      const entry =
        ledger[key] || {};

      const dateKey =
        payrollScheduleOSParseLedgerDateKey_(
          entry.date
        );

      if (!dateKey) {
        return;
      }

      const dayIndex =
        payrollScheduleOSDayIndexFromDateKey_(
          monday,
          dateKey
        );

      if (
        dayIndex < 0 ||
        dayIndex > 6
      ) {
        return;
      }

      const weeklyDay =
        weeklyInfo[dayIndex];

      if (!weeklyDay) {
        return;
      }

      const part =
        payrollScheduleOSPerformancePart_(
          entry.performance
        );

      (entry.castOuts || [])
        .forEach(
          function (ledgerOut) {
            /*
             * First apply the OUT to the person who is absent.
             * This catches same-day callouts such as Cecilia,
             * while deduplicating planned outs already supplied
             * by WeeklyOS.
             */
            const outName =
              String(
                ledgerOut.out || ""
              ).trim();

            if (outName) {
              const outPerson =
                peopleByName[
                  payrollScheduleOSNameKey_(
                    outName
                  )
                ];

              if (
                outPerson &&
                outPerson.days[dayIndex]
              ) {
                payrollScheduleOSApplyLedgerOut_(
                  outPerson.days[dayIndex],
                  part,
                  ledgerOut
                );
              }
            }

            /*
             * Then apply coverage to the person going IN.
             */
            const inName =
              String(
                ledgerOut.in || ""
              ).trim();

            if (
              !inName ||
              ledgerOut.noCoverNeeded ===
                true
            ) {
              return;
            }

            const inPerson =
              peopleByName[
                payrollScheduleOSNameKey_(
                  inName
                )
              ];

            if (
              !inPerson ||
              !inPerson.days[dayIndex]
            ) {
              return;
            }

            payrollScheduleOSApplyCoverage_(
              inPerson.days[dayIndex],
              part,
              ledgerOut,
              entry
            );
          }
        );
    }
  );
}

function payrollScheduleOSApplyLedgerOut_(
  dayModel,
  part,
  ledgerOut
) {
  const normalizedPart =
    part || "Unknown";

  const reason =
    String(
      ledgerOut.reason || "Out"
    ).trim();

  /*
   * Replace the normal show call for the affected
   * performance. Preserve rehearsal calls.
   */
  dayModel.calls =
    dayModel.calls.filter(
      function (call) {
        return !(
          call.type ===
            "SHOW" &&
          (
            call.part ===
              normalizedPart ||
            normalizedPart ===
              "Unknown"
          )
        );
      }
    );

  const duplicate =
    dayModel.outs.some(
      function (existing) {
        return (
          payrollScheduleOSNameKey_(
            existing.person
          ) ===
            payrollScheduleOSNameKey_(
              ledgerOut.out
            ) &&
          String(
            existing.part || ""
          ) ===
            String(
              normalizedPart
            )
        );
      }
    );

  if (duplicate) {
    return;
  }

  dayModel.outs.push({
    person:
      ledgerOut.out || "",

    role:
      ledgerOut.role || "",

    reason:
      reason,

    part:
      normalizedPart,

    approvalStatus:
      "",

    appliesTo:
      normalizedPart,

    source:
      ledgerOut.source || "Prep",

    noCoverNeeded:
      ledgerOut.noCoverNeeded === true,

    writeToInOutSheet:
      ledgerOut.writeToInOutSheet !==
        false,

    text:
      "OUT (" +
      reason +
      ")"
  });
}

function payrollScheduleOSApplyCoverage_(
  dayModel,
  part,
  coverageEntry,
  ledgerEntry
) {
  const normalizedPart = part || "Unknown";

  dayModel.calls = dayModel.calls.filter(function(call) {
    return !(
      call.type === "SHOW" &&
      (
        call.part === normalizedPart ||
        normalizedPart === "Unknown"
      )
    );
  });

  const coverage = {
    out: coverageEntry.out || "",
    in: coverageEntry.in || "",
    role: coverageEntry.role || "",
    reason: coverageEntry.reason || "",
    source: coverageEntry.source || "",
    part: normalizedPart,
    date: ledgerEntry.date || "",
    performance: ledgerEntry.performance || "",
    text:
      "1 Show Call - IN as " +
      (coverageEntry.role || "Cover")
  };

  const duplicate = dayModel.coverage.some(function(item) {
    return (
      payrollScheduleOSNameKey_(item.out) ===
        payrollScheduleOSNameKey_(coverage.out) &&
      payrollScheduleOSNameKey_(item.in) ===
        payrollScheduleOSNameKey_(coverage.in) &&
      payrollScheduleOSNameKey_(item.role) ===
        payrollScheduleOSNameKey_(coverage.role) &&
      String(item.part || "") === String(coverage.part || "")
    );
  });

  if (duplicate) return;

  dayModel.coverage.push(coverage);
  dayModel.calls.push({
    type: "COVERAGE",
    part: normalizedPart,
    role: coverage.role,
    out: coverage.out,
    text: coverage.text
  });
}

function payrollScheduleOSParseLedgerDateKey_(dateText) {
  if (!dateText) return "";

  if (typeof parseInOutDate_ === "function") {
    const parsed = parseInOutDate_(dateText);

    if (
      parsed instanceof Date &&
      !isNaN(parsed.getTime())
    ) {
      return payrollScheduleOSDateKey_(parsed);
    }
  }

  const year = new Date().getFullYear();
  const parsed = new Date(String(dateText || "") + ", " + year);

  return isNaN(parsed.getTime())
    ? ""
    : payrollScheduleOSDateKey_(parsed);
}

function payrollScheduleOSDayIndexFromDateKey_(
  monday,
  dateKey
) {
  const target = new Date(dateKey + "T12:00:00");
  const base = new Date(monday);
  base.setHours(12, 0, 0, 0);

  return Math.round(
    (target.getTime() - base.getTime()) /
    (24 * 60 * 60 * 1000)
  );
}

function payrollScheduleOSPerformancePart_(performanceText) {
  const text = String(performanceText || "");

  if (/MAT(?:INEE)?/i.test(text)) return "Mat";
  if (/EVE(?:NING)?/i.test(text)) return "Eve";

  const match = text.match(
    /(\d{1,2}):(\d{2})\s*(AM|PM)/i
  );

  if (!match) return "Unknown";

  let hour = Number(match[1]);
  const ampm = match[3].toUpperCase();

  if (ampm === "PM" && hour !== 12) hour += 12;
  if (ampm === "AM" && hour === 12) hour = 0;

  return hour < 17 ? "Mat" : "Eve";
}

function payrollScheduleOSStatus_() {
  const current = payrollScheduleOSCurrent_();

  return {
    system: current.system,
    version: current.version,
    weeklySheet: current.weeklySheet,
    weekStart: current.weekStart,
    weekEnd: current.weekEnd,
    people: current.counts.people,
    stageManagers: current.counts.stageManagers,
    actors: current.counts.actors,
    outs: current.counts.outs,
    coverage: current.counts.coverage,
    ledgerPerformances:
      current.counts.ledgerPerformances,
    durationMs: current.durationMs
  };
}

function payrollScheduleOSNameKey_(value) {
  return String(value || "")
    .toLowerCase()
    .replace(/\./g, "")
    .replace(/\s+/g, " ")
    .trim();
}

function payrollScheduleOSDateKey_(date) {
  return Utilities.formatDate(
    date,
    Session.getScriptTimeZone(),
    "yyyy-MM-dd"
  );
}

function payrollScheduleOSAddDays_(date, numberOfDays) {
  const output = new Date(date);
  output.setDate(output.getDate() + numberOfDays);
  return output;
}

function payrollScheduleOSCountOuts_(people) {
  return people.reduce(function(total, person) {
    return total + person.days.reduce(function(dayTotal, day) {
      return dayTotal + day.outs.length;
    }, 0);
  }, 0);
}

function payrollScheduleOSCountCoverage_(people) {
  return people.reduce(function(total, person) {
    return total + person.days.reduce(function(dayTotal, day) {
      return dayTotal + day.coverage.length;
    }, 0);
  }, 0);
}

