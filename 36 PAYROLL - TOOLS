function getPayrollNotes_(sheet) {
  const values = sheet.getRange(1, 1, sheet.getLastRow(), 1).getDisplayValues();

  for (let i = 0; i < values.length; i++) {
    if (String(values[i][0] || "").trim().toUpperCase() === "NOTES") {
      return sheet.getRange(i + 1, 2).getDisplayValue();
    }
  }

  return "";
}

function saveOrReplacePayrollPdfToDrive_(pdfBlob, fileName) {
  const folder = DriveApp.getFolderById(PAYROLL_DRIVE_FOLDER_ID);
  const existingFiles = folder.getFilesByName(fileName);

  while (existingFiles.hasNext()) {
    existingFiles.next().setTrashed(true);
  }

  return folder.createFile(pdfBlob);
}

function formatPayrollDate_(date) {
  if (!(date instanceof Date)) {
    date = new Date(date);
  }

  return Utilities.formatDate(date, Session.getScriptTimeZone(), "M.d.yy");
}

function exportSheetAsPdf_(sheet) {
  const ss = sheet.getParent();

  const url =
    `https://docs.google.com/spreadsheets/d/${ss.getId()}/export?` +
    `format=pdf` +
    `&gid=${sheet.getSheetId()}` +
    `&size=letter` +
    `&portrait=false` +
    `&fitw=true` +
    `&sheetnames=false` +
    `&printtitle=false` +
    `&pagenumbers=false` +
    `&gridlines=false` +
    `&fzr=false`;

  const response = UrlFetchApp.fetch(url, {
    headers: {
      Authorization: `Bearer ${ScriptApp.getOAuthToken()}`
    }
  });

  return response.getBlob();
}

function exportPayrollSheetWithSafePageBreaks_(payrollSheet) {
  const ss = payrollSheet.getParent();
  const originalSheet = ss.getActiveSheet();

  const tempSheet = ss.insertSheet(`TEMP Payroll PDF ${Date.now()}`);

  try {
    buildPayrollPdfExportSheet_(payrollSheet, tempSheet);

    ss.setActiveSheet(tempSheet);
    const blob = exportSheetAsPdf_(tempSheet);

    return blob;

  } finally {
    ss.deleteSheet(tempSheet);
    ss.setActiveSheet(originalSheet);
  }
}

function buildPayrollPdfExportSheet_(source, target) {
  const lastCol = 10; // A:J only

  const maxCols = target.getMaxColumns();
  if (maxCols > lastCol) {
    target.deleteColumns(lastCol + 1, maxCols - lastCol);
  }

  for (let c = 1; c <= lastCol; c++) {
    target.setColumnWidth(c, source.getColumnWidth(c));
  }

  let targetRow = 1;

  // PAGE 1: Header + Stage Managers only
  source.getRange(1, 1, 16, lastCol)
    .copyTo(target.getRange(targetRow, 1), { contentsOnly: false });

  copyRowHeights_(source, target, 1, 16, targetRow);
  targetRow += 16;

  // Clean white spacer to force next page
  targetRow = addWhitePageSpacer_(target, targetRow, lastCol, 560);

  // PAGE 2+: Actors through Notes
  const notesRow = findNotesRow_(source);
  const actorStartRow = findRowByTextInColumnA_(source, "ACTORS");
  const rowsToCopy = notesRow + 1 - actorStartRow;

  source.getRange(actorStartRow, 1, rowsToCopy, lastCol)
    .copyTo(target.getRange(targetRow, 1), { contentsOnly: false });

  copyRowHeights_(source, target, actorStartRow, rowsToCopy, targetRow);
}

function addWhitePageSpacer_(sheet, row, lastCol, height) {
  sheet.insertRowsAfter(row - 1, 1);

  const range = sheet.getRange(row, 1, 1, lastCol);
  range
    .clearContent()
    .clearFormat()
    .setBackground("#ffffff")
    .setBorder(false, false, false, false, false, false);

  sheet.setRowHeight(row, height);

  return row + 1;

}

function copyRowHeights_(source, target, sourceStartRow, numRows, targetStartRow) {
  for (let i = 0; i < numRows; i++) {
    target.setRowHeight(
      targetStartRow + i,
      source.getRowHeight(sourceStartRow + i)
    );
  }
}

function insertWhitePageBreakRow_(sheet, beforeRow, height) {
  sheet.insertRowsBefore(beforeRow, 1);

  const lastCol = 10; // A:J only
  const range = sheet.getRange(beforeRow, 1, 1, lastCol);

  range
    .clearContent()
    .clearFormat()
    .setBackground("#ffffff")
    .setBorder(false, false, false, false, false, false);

  sheet.setRowHeight(beforeRow, height);
}

function findRowByTextInColumnA_(sheet, text) {
  const values = sheet.getRange(1, 1, sheet.getLastRow(), 1).getDisplayValues();
  const target = String(text).trim().toUpperCase();

  for (let i = 0; i < values.length; i++) {
    if (String(values[i][0] || "").trim().toUpperCase() === target) {
      return i + 1;
    }
  }

  return -1;
}
