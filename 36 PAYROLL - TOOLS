/*************************************************
 * CAST REPORTS
 *************************************************/

function CASTREPORT2_old(actorName, blockRange) {
  if (!actorName || !blockRange) return "";

  const ss = SpreadsheetApp.getActiveSpreadsheet();
  const payroll = ss.getSheetByName("Payroll");
  const castList = ss.getSheetByName("Cast List");

  if (!payroll || !castList) return "";

  const dateDisplays = payroll.getRange("B3:H3").getDisplayValues()[0];
  const actorMap = getActorMap3_(castList);

  const actorKey = String(actorName).trim().toLowerCase();
  const actorInfo = actorMap[actorKey];

  if (!actorInfo) return "";

  const role = String(actorInfo.role || "").trim();
  const roleLower = role.toLowerCase();
  const shortName = actorInfo.shortName;

  // Stage-management subs are handled by the SM report functions.
  if (
    roleLower === "psm / asm sub" ||
    roleLower.includes("stage manager sub") ||
    roleLower.includes("sm sub")
  ) {
    return "";
  }

  const events = parseBlock3_(blockRange, dateDisplays);
  if (events.out.totalShows === 0) return "";

  const reasonText = reasonSummary3_(events.out.reasonCounts, events.out.totalShows);

  const firstPart =
    `- ${shortName} OUT (${events.out.totalShows} ` +
    `${events.out.totalShows === 1 ? "show" : "shows"}) (${reasonText})`;

  // Swing / understudy OUTs must still appear even though they do not
  // have a principal role whose replacement needs to be matched here.
  const isUnderstudyOrSwing =
    roleLower === "swing" ||
    roleLower.includes("swing") ||
    roleLower.includes("understudy") ||
    roleLower === "u/s";

  if (isUnderstudyOrSwing || !role) {
    return `${firstPart}: ${dateSummary3_(events.out.dates)}`;
  }

  const coverage = [];
  const lastCoverageRow = findNotesRow_(payroll) - 1;

  for (let r = 5; r <= lastCoverageRow; r++) {
    const coverActor = String(
      payroll.getRange(r, 1).getDisplayValue() || ""
    ).trim();

    const upper = coverActor.toUpperCase();

    if (!coverActor) continue;
    if (
      upper === "ACTORS" ||
      upper === "STAGE MANAGERS" ||
      upper === "NOTES"
    ) {
      continue;
    }

    const coverKey = coverActor.toLowerCase();

    if (coverKey === actorKey) continue;
    if (!actorMap[coverKey]) continue;

    const coverBlock = payroll.getRange(r, 2, 2, 7).getDisplayValues();
    const coverEvents = parseBlock3_(coverBlock, dateDisplays);

    const matchingRole = Object.keys(coverEvents.in).find(inRole => {
      return normalizePayrollRole3_(inRole) === normalizePayrollRole3_(role);
    });

    if (!matchingRole) continue;

    const data = coverEvents.in[matchingRole];

    coverage.push({
      sort: getFirstDateSort3_(data.dates),
      text:
        `${actorMap[coverKey].shortName} IN as ${role} ` +
        `(${data.shows} ${data.shows === 1 ? "show" : "shows"}): ` +
        `${dateSummary3_(data.dates)}`
    });
  }

  if (coverage.length > 0) {
    coverage.sort((a, b) => a.sort - b.sort);
    return `${firstPart}: ${coverage.map(item => item.text).join("; ")}`;
  }

  return `${firstPart}: ${dateSummary3_(events.out.dates)}`;
}

function CASTREPORT3_old(actorName, blockRange) {
  return CASTREPORT2_old(actorName, blockRange);
}

function CASTREPORT4_old(actorName, blockRange) {
  return CASTREPORT2_old(actorName, blockRange);
}

function normalizePayrollRole3_(role) {
  return String(role || "")
    .toLowerCase()
    .normalize("NFD")
    .replace(/[\u0300-\u036f]/g, "")
    .replace(/understudy/g, "us")
    .replace(/[^a-z0-9]/g, "");
}

/*************************************************
 * STAGE MANAGER REPORTS
 *
 * SMREPORT2 / SMREPORT3 are used by Payroll notes.
 *
 * This version handles three cases:
 * 1. Principal SM OUT notes.
 * 2. Regular SM IN notes.
 * 3. SM Sub IN notes when nobody is OUT, but another SM is
 *    marked as Office Show for that performance.
 *
 * Example:
 * - Zach D. IN (1 show) as ASM: Wed 7/1 Eve (RZ = Office Show)
 *************************************************/

function SMREPORT2_old(actorName, blockRange) {
  if (!actorName || !blockRange) return "";

  const ss = SpreadsheetApp.getActiveSpreadsheet();
  const payroll = ss.getSheetByName("Payroll");
  const castList = ss.getSheetByName("Cast List");

  const dateDisplays = payroll.getRange("B3:H3").getDisplayValues()[0];
  const actorMap = getActorMap3_(castList);

  const actorKey = String(actorName).trim().toLowerCase();
  const actorInfo = actorMap[actorKey] || {
    role: "",
    shortName: makeShortName3_(actorName)
  };

  const shortName = actorInfo.shortName;
  const roleText = String(actorInfo.role || "").toLowerCase();
  const events = parseBlock3_(blockRange, dateDisplays);
  const sections = [];

  /*************************************************
   * CASE 1: This person is OUT.
   *************************************************/
  if (events.out.totalShows > 0) {
    const reasonText = reasonSummary3_(events.out.reasonCounts, events.out.totalShows);

    sections.push(
      `- ${shortName} OUT (${events.out.totalShows} ${events.out.totalShows === 1 ? "show" : "shows"}) (${reasonText}): ${dateSummary3_(events.out.dates)}`
    );
  }

  /*************************************************
   * CASE 2 / 3: This person is IN.
   *
   * Principal SMs still report normal IN lines.
   * SM subs only report IN lines when the IN is NOT covering
   * a matching principal SM OUT.
   *************************************************/
  const isSub = isStageManagerSub3_(actorKey, roleText);

  Object.keys(events.in).forEach(role => {
    const data = events.in[role];

    if (!isSub) {
      sections.push(
        `- ${shortName} IN as ${role} (${data.shows} ${data.shows === 1 ? "show" : "shows"}): ${dateSummary3_(data.dates)}`
      );
      return;
    }

    const standaloneSubDates = data.dates.filter(entry => {
      return !hasMatchingPrincipalSMOut3_(payroll, actorMap, actorKey, role, entry, dateDisplays);
    });

    if (standaloneSubDates.length === 0) return;

    const officeShowNote = getOfficeShowNoteForEntries3_(
      payroll,
      actorMap,
      actorKey,
      standaloneSubDates,
      dateDisplays
    );

    sections.push(
      `- ${shortName} IN (${standaloneSubDates.length} ${standaloneSubDates.length === 1 ? "show" : "shows"}) as ${role}: ${dateSummary3_(standaloneSubDates)}${officeShowNote}`
    );
  });

  return sections.join("\n");
}

