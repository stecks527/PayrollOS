 * - refreshPayrollNotesFormula_
 *
 * Payroll sheet cells are output, not a source of truth.
 * Editing Payroll must not trigger formula restoration or
 * create a second Payroll write path.
 *************************************************/


function payrollNotesOnEdit_(e) {
  if (
    !e ||
    !e.range
  ) {
    return;
  }

  const sheet =
    e.range.getSheet();

  if (
    sheet.getName() !==
    "Payroll"
  ) {
    return;
  }

  /*
   * Intentionally no automatic rebuild from Payroll edits.
   *
   * Canonical refreshes happen when:
   * - Fill Payroll From Weekly runs
   * - Prep commits current performance data
   * - PayrollOS().refresh() is called
   *
   * This compatibility handler remains so the central
   * onEdit router does not need to change today.
   */
  return;
}


/*
 * Compatibility name retained temporarily.
 * It writes model-driven editable notes and never restores
 * =PAYROLLNOTES() or searches for CODE OUTPUT.
 */
function refreshPayrollNotesFormula_() {
  if (
    typeof PayrollOS ===
    "function"
  ) {
    return PayrollOS()
      .notes({
        forceBuild:
          true
      });
  }

  if (
    typeof PayrollNotesWriterOS ===
    "function"
  ) {
    return PayrollNotesWriterOS()
      .write();
  }

  return null;
}

