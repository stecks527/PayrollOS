/*************************************************
 * PAYROLL BLOCK PARSING HELPERS
 *************************************************/

function parseBlock3_(blockRange, dateDisplays) {
  const result = {
    out: {
      totalShows: 0,
      reasonCounts: {},
      dates: []
    },
    in: {}
  };

  for (let col = 0; col < 7; col++) {
    parseCell3_(String(blockRange[0][col] || ""), col, "", result, dateDisplays);
    parseCell3_(String(blockRange[1][col] || ""), col, "Eve", result, dateDisplays);
  }

  return result;
}

function parseCell3_(cellText, colIndex, defaultPart, result, dateDisplays) {
  const text = String(cellText || "");

  const lines = text
    .split("\n")
    .map(line => line.trim())
    .filter(Boolean);

  lines.forEach(line => {
    /*
     * OUT parsing
     *
     * Accepts:
     * OUT (Sick)
     * OUT - Sick
     * OUT Sick
     * OUT
     */
    if (/\bOUT\b/i.test(line)) {
      if (!shouldCountOutLine3_(line)) return;

      const parenthesesMatch = line.match(/\bOUT\b\s*\((.*?)\)/i);
      const dashMatch = line.match(/\bOUT\b\s*[-–—:]\s*(.+)$/i);
      const plainMatch = line.match(/\bOUT\b\s+(.+)$/i);

      let reason = "";

      if (parenthesesMatch) {
        reason = parenthesesMatch[1].trim();
      } else if (dashMatch) {
        reason = dashMatch[1].trim();
      } else if (plainMatch) {
        reason = plainMatch[1]
          .replace(/\s*-\s*Mat\s*&\s*Eve$/i, "")
          .replace(/\s*-\s*Mat$/i, "")
          .replace(/\s*-\s*Eve$/i, "")
          .trim();
      }

      /*
       * Remove performance labels if they accidentally became
       * part of the reason.
       */
      reason = reason
        .replace(/\bMat\s*&\s*Eve\b/gi, "")
        .replace(/\bMatinee\b/gi, "")
        .replace(/\bEvening\b/gi, "")
        .replace(/\bMat\b/gi, "")
        .replace(/\bEve\b/gi, "")
        .replace(/^[\s\-–—:]+|[\s\-–—:]+$/g, "")
        .trim();

      if (!reason) reason = "OUT";

      const part = partFromLine3_(line, defaultPart);

      result.out.totalShows++;
      result.out.reasonCounts[reason] =
        (result.out.reasonCounts[reason] || 0) + 1;

      result.out.dates.push(
        makeDateEntry3_(colIndex, part, dateDisplays)
      );

      return;
    }

    /*
     * IN parsing
     */
    const inMatch = line.match(/\bIN\s+as\s+(.+)/i);

    if (inMatch) {
      let role = inMatch[1]
        .trim()
        .replace(/\s*\(.*?\)\s*$/i, "")
        .replace(/\s*-\s*Mat\s*&\s*Eve$/i, "")
        .replace(/\s*-\s*Mat$/i, "")
        .replace(/\s*-\s*Eve$/i, "")
        .trim();

      const part = partFromLine3_(line, defaultPart);

      if (!result.in[role]) {
        result.in[role] = {
          shows: 0,
          dates: []
        };
      }

      result.in[role].shows++;
      result.in[role].dates.push(
        makeDateEntry3_(colIndex, part, dateDisplays)
      );
    }
  });
}

function shouldCountOutLine3_(line) {
  const lowerLine = String(line || "").toLowerCase();

  /*
   * Only reject the individual OUT line when that line itself
   * clearly says it is a rehearsal-only absence.
   *
   * Do not inspect the entire cell. An understudy cell may contain
   * both rehearsal information and a legitimate show OUT.
   */
  const rehearsalOnlyPatterns = [
    /\bout\s+from\s+reh\b/i,
    /\bout\s+from\s+rehearsal\b/i,
    /\bout\s+of\s+reh\b/i,
    /\bout\s+of\s+rehearsal\b/i,
    /\brehearsal\s+only\b/i,
    /\bput[- ]?in\s+only\b/i
  ];

  return !rehearsalOnlyPatterns.some(pattern => pattern.test(lowerLine));
}

function partFromLine3_(line, defaultPart) {
  if (/mat\s*&\s*eve/i.test(line)) return "MatEve";
  if (/\bmat\b/i.test(line)) return "Mat";
  if (/\beve\b/i.test(line)) return "Eve";

  return defaultPart || "";
}

function makeDateEntry3_(index, part, dateDisplays) {
  return {
    base: formatDate3_(index, dateDisplays),
    part: part
  };
}

function formatDate3_(index, dateDisplays) {
  const display = String(dateDisplays[index] || "");

  const months = {
    January: 1,
    February: 2,
    March: 3,
    April: 4,
    May: 5,
    June: 6,
    July: 7,
    August: 8,
    September: 9,
    October: 10,
    November: 11,
    December: 12
  };

  const match = display.match(/^(\w+),\s+(\w+)\s+(\d+)/);

  if (match) {
    return `${match[1].slice(0, 3)} ${months[match[2]]}/${match[3]}`;
  }

  return display;
}

function dateSummary3_(entries) {
  if (!entries || entries.length === 0) return "";

  const grouped = {};
  const order = [];

  entries.forEach(entry => {
    const base = entry.base;

    if (!grouped[base]) {
      grouped[base] = {
        base: base,
        mat: false,
        eve: false,
        plain: false
      };

      order.push(base);
    }

    if (entry.part === "MatEve") {
      grouped[base].mat = true;
      grouped[base].eve = true;
    } else if (entry.part === "Mat") {
      grouped[base].mat = true;
    } else if (entry.part === "Eve") {
      grouped[base].eve = true;
    } else {
      grouped[base].plain = true;
    }
  });

  const dates = order.map(base => {
    const g = grouped[base];
    const match = base.match(/^(\w+)\s+(\d+)\/(\d+)$/);

    return {
      base: base,
      month: match ? Number(match[2]) : 0,
      day: match ? Number(match[3]) : 0,
      sort: match ? Number(match[2]) * 100 + Number(match[3]) : 0,
      display: displayGroup3_(g),
      startDisplay: displayEndpoint3_(g, "start"),
      endDisplay: displayEndpoint3_(g, "end")
    };
  });

  dates.sort((a, b) => a.sort - b.sort);

  const ranges = [];
  let start = dates[0];
  let end = dates[0];

  for (let i = 1; i < dates.length; i++) {
    const current = dates[i];

    if (current.month === end.month && current.day === end.day + 1) {
      end = current;
    } else {
      ranges.push(formatRange3_(start, end));
      start = current;
      end = current;
    }
  }

  ranges.push(formatRange3_(start, end));

  if (ranges.length === 1) return ranges[0];
  if (ranges.length === 2) return ranges.join(" & ");

  return ranges.slice(0, -1).join(", ") + " & " + ranges[ranges.length - 1];
}

function displayGroup3_(group) {
  if (group.mat && group.eve) return `${group.base} Mat + Eve`;
  if (group.mat) return `${group.base} Mat`;
  if (group.eve) return `${group.base} Eve`;

  return group.base;
}

function displayEndpoint3_(group, side) {
  if (group.mat && group.eve) {
    return `${group.base} ${side === "start" ? "Mat" : "Eve"}`;
  }

  if (group.mat) return `${group.base} Mat`;
  if (group.eve) return `${group.base} Eve`;

  return group.base;
}

function formatRange3_(start, end) {
  if (start.sort === end.sort) return start.display;

  return `${start.startDisplay} - ${end.endDisplay}`;
}

function reasonSummary3_(reasonCounts, totalShows) {
  return Object.entries(reasonCounts)
    .map(([reason, count]) => {
      if (count === totalShows) return reason;
      return `${count} ${reason}`;
    })
    .join(" + ");
}

function getFirstDateSort3_(entries) {
  if (!entries || entries.length === 0) return 99999;

  let earliest = 99999;

  entries.forEach(entry => {
    const parts = String(entry.base || "").split(" ");
    if (parts.length < 2) return;

    const dateParts = parts[1].split("/");
    if (dateParts.length < 2) return;

    const month = Number(dateParts[0]);
    const day = Number(dateParts[1]);

    let sortValue = month * 100 + day;

    if (entry.part === "Mat") sortValue += 0.1;
    if (entry.part === "Eve") sortValue += 0.5;

    earliest = Math.min(earliest, sortValue);
  });

  return earliest;
}

function findNotesRow_(sheet) {
  const values = sheet.getRange(1, 1, sheet.getLastRow(), 1).getDisplayValues();

  for (let i = 0; i < values.length; i++) {
    if (String(values[i][0] || "").trim().toUpperCase() === "NOTES") {
      return i + 1;
    }
  }

  return sheet.getLastRow();
}

/*************************************************
 * PAYROLL NOTES — ON EDIT
 * Version: 2.0.0
 * Status: CANONICAL / SAFE
 *
 * Replace the old:
