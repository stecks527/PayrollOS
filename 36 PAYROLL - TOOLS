function OTREPORT2(actorName, wedHours) {
  const rawHours = Number(wedHours);
  const roundedHours = Math.round(rawHours * 10) / 10;

  if (!roundedHours || roundedHours <= 0) return "";

  const displayHours = roundedHours.toFixed(1).replace(".0", "");

  return (
    `- OT: DADO: ${actorName} gets ${displayHours} hours of OT ` +
    `($61.68 per hour or part thereof) for rehearsing the day after the day off.`
  );
}


/*************************************************
 * STAGE MANAGER OFFICE SHOW HELPERS
 *************************************************/

function isStageManagerSub3_(actorKey, roleText) {
  return (
    String(roleText || "").includes("sub") ||
    String(actorKey || "").includes("zach de brino") ||
    String(actorKey || "").includes("kristin newhouse")
  );
}

function hasMatchingPrincipalSMOut3_(payroll, actorMap, currentActorKey, role, entry, dateDisplays) {
  const lastCoverageRow = findNotesRow_(payroll) - 1;

  for (let r = 5; r <= lastCoverageRow; r++) {
    const name = String(payroll.getRange(r, 1).getValue() || "").trim();
    if (!name) continue;

    const upper = name.toUpperCase();
    if (upper === "STAGE MANAGERS" || upper === "ACTORS" || upper === "NOTES") continue;

    const key = name.toLowerCase();
    if (key === currentActorKey) continue;

    const info = actorMap[key];
    if (!info) continue;

    const personRole = String(info.role || "").trim();
    const personRoleLower = personRole.toLowerCase();

    // Only principal SM rows can create a true coverage OUT.
    if (personRoleLower.includes("sub")) continue;
    if (personRoleLower !== String(role || "").toLowerCase()) continue;

    const block = payroll.getRange(r, 2, 2, 7).getValues();
    const events = parseBlock3_(block, dateDisplays);

    if (events.out.dates.some(outEntry => sameDateEntry3_(outEntry, entry))) {
      return true;
    }
  }

  return false;
}

function getOfficeShowNoteForEntries3_(payroll, actorMap, currentActorKey, entries, dateDisplays) {
  const officePeople = [];
  const lastCoverageRow = findNotesRow_(payroll) - 1;

  for (let r = 5; r <= lastCoverageRow; r++) {
    const name = String(payroll.getRange(r, 1).getValue() || "").trim();
    if (!name) continue;

    const upper = name.toUpperCase();
    if (upper === "STAGE MANAGERS" || upper === "ACTORS" || upper === "NOTES") continue;

    const key = name.toLowerCase();
    if (key === currentActorKey) continue;

    const block = payroll.getRange(r, 2, 2, 7).getDisplayValues();

    for (let col = 0; col < 7; col++) {
      const topText = String(block[0][col] || "");
      const bottomText = String(block[1][col] || "");
      const base = formatDate3_(col, dateDisplays);

      entries.forEach(entry => {
        if (entry.base !== base) return;

        const checkTop = entry.part !== "Eve";
        const checkBottom = entry.part === "Eve" || entry.part === "MatEve";

        if (
          (checkTop && /office show/i.test(topText)) ||
          (checkBottom && /office show/i.test(bottomText))
        ) {
          const label = getOfficeShowPayrollLabel3_(name, actorMap);
          if (!officePeople.includes(label)) officePeople.push(label);
        }
      });
    }
  }

  if (officePeople.length === 0) return "";

  return ` (${officePeople.join(" + ")} = Office Show)`;
}

function getOfficeShowPayrollLabel3_(name, actorMap) {
  const key = String(name || "").trim().toLowerCase();

  const overrides = {
    "rachel a. zucker": "RZ",
    "chris steckel": "Chris S.",
    "kristin newhouse": "Kristin N.",
    "zach de brino": "Zach D."
  };

  if (overrides[key]) return overrides[key];
  if (actorMap[key] && actorMap[key].shortName) return actorMap[key].shortName;

  return makeShortName3_(name);
}

function sameDateEntry3_(a, b) {
  return String(a.base || "") === String(b.base || "") &&
    normalizePayrollPart3_(a.part) === normalizePayrollPart3_(b.part);
}

function normalizePayrollPart3_(part) {
  if (part === "MatEve") return "MatEve";
  return String(part || "");
}

